(type u64 (primitive u64))
(type u32 (primitive u32))
(type u8 (primitive u8))
(type str (primitive String))
(type index (primitive AstIdx))
(type adata (primitive AstData))
(type predicate (primitive Predicate))
(type empty (primitive Empty))


(type SimpleAst extern
  (enum 
  ;; Arithmetic operators
  (Add (a index) (b index) )
  (Mul (a index) (b index) )
  (Pow (a index) (b index) )
  ;; Bitwise operators
  (And (a index) (b index) )
  (Or (a index) (b index) )
  (Xor (a index) (b index) )
  (Neg (a index) )
  ;; Shift operators
  (Lshr (a index) (b index) )
  ;; Special types
  (Constant (c u64) (width u8) )
  (Symbol (id u32) (width u8) )
  (Zext (a index) (b index) )
  (Trunc (a index) (b index) )
  (ICmp (a predicate) (b index) (c index) )
  (Select (a index) (b index) (c index) )
  (Extract (a index) (b index) (c index) )
  (Concat (a index) (t index) )
  (Carry (a index) (b index) (c index) )
  ))

(type ConstantWithExpectedValue extern
  (enum 
  ;; Arithmetic operators
  (Only (input SimpleAst) (expected_value u64) )
  ))

;; Below are wrappers for constructing instances of the AST types.
;; Arithmetic
(decl Add (index index) SimpleAst)
(extern constructor Add add)
(decl Mul (index index) SimpleAst)
(extern constructor Mul mul)
(decl Pow (index index) SimpleAst)
(extern constructor Pow pow)
;; Bitwise
(decl And (index index) SimpleAst)
(extern constructor And and)
(decl Or (index index) SimpleAst)
(extern constructor Or or)
(decl Xor (index index) SimpleAst)
(extern constructor Xor xor)
(decl Neg (index) SimpleAst)
(extern constructor Neg neg)
(decl Lshr (index index) SimpleAst)
(extern constructor Lshr lshr)
(decl Any (index) SimpleAst)
(extern constructor Any any)

(decl lookup_value (SimpleAst) index)
(extern extractor lookup_value lookup_value)
(extern constructor lookup_value lookup_id)

;; Special types
(decl Constant (u64 u8) SimpleAst)
(extern constructor Constant constant)
(decl Symbol (u32 u8) SimpleAst)
(extern constructor Symbol symbol)
(decl Zext (index index) SimpleAst)
(extern constructor Zext zext)
(decl Trunc (index index) SimpleAst)
(extern constructor Trunc trunc)

(decl ICmp (predicate index index) SimpleAst)
(extern constructor ICmp icmp)
(decl Select (index index index) SimpleAst)
(extern constructor Select select)
(decl Extract (index index index) SimpleAst)
(extern constructor Extract extract)
(decl Concat (index index) SimpleAst)
(extern constructor Concat concat)
(decl Carry (index index index) SimpleAst)
(extern constructor Carry carry)

;; Constant folding utilities
(decl FoldAdd (index index) SimpleAst)
(extern constructor FoldAdd fold_add)

(decl GetWidth (index) u8)
(extern constructor GetWidth get_width)


(decl pure partial is_constant_modulo (u64 u64 u8) empty)
(extern constructor is_constant_modulo is_constant_modulo)


(decl pure partial is_icmp_eq (predicate) empty)
(extern constructor is_icmp_eq is_icmp_eq)
(decl pure partial is_icmp_ne (predicate) empty)
(extern constructor is_icmp_ne is_icmp_ne)
(decl pure partial is_icmp_ugt (predicate) empty)
(extern constructor is_icmp_ugt is_icmp_ugt)
(decl pure partial is_icmp_uge (predicate) empty)
(extern constructor is_icmp_uge is_icmp_uge)
(decl pure partial is_icmp_ult (predicate) empty)
(extern constructor is_icmp_ult is_icmp_ult)
(decl pure partial is_icmp_ule (predicate) empty)
(extern constructor is_icmp_ule is_icmp_ule)
(decl pure partial is_icmp_sgt (predicate) empty)
(extern constructor is_icmp_sgt is_icmp_sgt)
(decl pure partial is_icmp_sge (predicate) empty)
(extern constructor is_icmp_sge is_icmp_sge)
(decl pure partial is_icmp_slt (predicate) empty)
(extern constructor is_icmp_slt is_icmp_slt)
(decl pure partial is_icmp_sle (predicate) empty)
(extern constructor is_icmp_sle is_icmp_sle)

(decl PredEq () predicate)
(extern constructor PredEq pred_eq)
(decl PredNe () predicate)
(extern constructor PredNe pred_ne)
(decl PredUgt () predicate)
(extern constructor PredUgt pred_ugt)
(decl PredUge () predicate)
(extern constructor PredUge pred_uge)
(decl PredUlt () predicate)
(extern constructor PredUlt pred_ult)
(decl PredUle () predicate)
(extern constructor PredUle pred_ule)
(decl PredSgt () predicate)
(extern constructor PredSgt pred_sgt)
(decl PredSge () predicate)
(extern constructor PredSge pred_sge)
(decl PredSlt () predicate)
(extern constructor PredSlt pred_slt)
(decl PredSle () predicate)
(extern constructor PredSle pred_sle)
;; Declare our top-level lowering function. We will attach rules to this
;; declaration for lowering various patterns of `SimpleAst` inputs.
(decl partial lower (SimpleAst) SimpleAst)

(convert SimpleAst index
lookup_value)

