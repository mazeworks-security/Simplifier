;; mul_constant_to_left_1:
;; (a:i64*c1:i64) => (c1:i64*a:i64)
(rule 0 (lower (SimpleAst.Mul a c1))
(if-let _ (rule_mul_constant_to_left_1_precondition c1))
    (Mul (Any c1) (Any a))
)

;; mul_constant_to_left_2:
;; ((c1:i64*a:i64)*b:i64) => (c1:i64*(a:i64*b:i64))
(rule 1 (lower (SimpleAst.Mul (SimpleAst.Mul c1 a) b))
(if-let _ (rule_mul_constant_to_left_2_precondition c1))
    (Mul (Any c1) (Mul (Any a) (Any b)))
)

;; mul_constant_to_left_3:
;; (c1:i64*(c2:i64*a:i64)) => ((c1:i64*c2:i64)*a:i64)
(rule 2 (lower (SimpleAst.Mul c1 (SimpleAst.Mul c2 a)))
(if-let _ (rule_mul_constant_to_left_3_precondition c1 c2))
    (Mul (Mul (Any c1) (Any c2)) (Any a))
)

;; mul_constant_to_left_4:
;; (c1:i64*c2:i64) => (c1:i64*c2:i64)
(rule 3 (lower (SimpleAst.Mul c1 c2))
(if-let _ (rule_mul_constant_to_left_4_precondition c1 c2))
    (Mul (Any c1) (Any c2))
)

;; add_constant_to_left_1:
;; (a:i64+c1:i64) => (c1:i64+a:i64)
(rule 4 (lower (SimpleAst.Add a c1))
(if-let _ (rule_add_constant_to_left_1_precondition c1))
    (Add (Any c1) (Any a))
)

;; add_constant_to_left_2:
;; ((c1:i64+a:i64)+b:i64) => (c1:i64+(a:i64+b:i64))
(rule 5 (lower (SimpleAst.Add (SimpleAst.Add c1 a) b))
(if-let _ (rule_add_constant_to_left_2_precondition c1))
    (Add (Any c1) (Add (Any a) (Any b)))
)

;; add_constant_to_left_3:
;; (c1:i64+(c2:i64+a:i64)) => ((c1:i64+c2:i64)+a:i64)
(rule 6 (lower (SimpleAst.Add c1 (SimpleAst.Add c2 a)))
(if-let _ (rule_add_constant_to_left_3_precondition c1 c2))
    (Add (Add (Any c1) (Any c2)) (Any a))
)

;; add_constant_to_left_4:
;; (c1:i64+c2:i64) => (c1:i64+c2:i64)
(rule 7 (lower (SimpleAst.Add c1 c2))
(if-let _ (rule_add_constant_to_left_4_precondition c1 c2))
    (Add (Any c1) (Any c2))
)

;; and_constant_to_left_1:
;; (a:i64&c1:i64) => (c1:i64&a:i64)
(rule 8 (lower (SimpleAst.And a c1))
